<?xml version="1.0" encoding="utf-8"?>
<PreviewLayout xmlns="https://github.com/Zielony/Ghurund/Engine/UISchema.xsd" namespace="Preview">
	<PreviewLayout.Material shader="lib://Ghurund/shaders/DirectX/ui/color.hlsl">
		<Parameter name="backgroundColor" value="#ffcccccc"/>
	</PreviewLayout.Material>
	<ControlGroup width="Parent.Width" height="Parent.Height">
		<ControlGroup.Material color="theme://color/background" shader="lib://Ghurund/shaders/DirectX/ui/control.hlsl"/>
		<ControlContainer width="Parent.Width" top="Parent.Top" bottom="'controls'.Top"
						  name="container">
			<ControlGroup>
				<Control width="433" height="56" scaleMode="fit">
					<Control.Material shader="lib://Ghurund/shaders/DirectX/ui/image.hlsl">
						<Parameter name="image" value="images\buttons.png"/>
					</Control.Material>
				</Control>
			</ControlGroup>
		</ControlContainer>
		<ControlGroup left="10" width="Parent.Width" name="controls">
			<ControlGroup.Bottom path="Parent.Bottom" offset="-10"/>
			<Button name="color1" layout="lib://Ghurund\layouts\ButtonImageLayout.xml" width="24" height="24">
				<Button.Material shader="lib://Ghurund/shaders/DirectX/ui/controlWithShadow.hlsl">
					<Parameter name="backgroundColor" value="#ffd32f2f"/>
				</Button.Material>
			</Button>
			<Button name="color2" layout="lib://Ghurund\layouts\ButtonImageLayout.xml" width="24" height="24">
				<Button.Left path="'color1'.Right" offset="10"/>
				<Button.Material shader="lib://Ghurund/shaders/DirectX/ui/controlWithShadow.hlsl">
					<Parameter name="backgroundColor" value="#ff1976d2"/>
				</Button.Material>
			</Button>
			<Button name="color3" layout="lib://Ghurund\layouts\ButtonImageLayout.xml" width="24" height="24">
				<Button.Left path="'color2'.Right" offset="10"/>
				<Button.Material shader="lib://Ghurund/shaders/DirectX/ui/controlWithShadow.hlsl">
					<Parameter name="backgroundColor" value="#ffffa000"/>
				</Button.Material>
			</Button>
			<Button name="color4" layout="lib://Ghurund\layouts\ButtonImageLayout.xml" width="24" height="24">
				<Button.Left path="'color3'.Right" offset="10"/>
				<Button.Material shader="lib://Ghurund/shaders/DirectX/ui/controlWithShadow.hlsl">
					<Parameter name="backgroundColor" value="#ff388e3c"/>
				</Button.Material>
			</Button>
			<Button name="colorTheme" layout="lib://Ghurund\layouts\ButtonImageLayout.xml" width="24" height="24">
				<Button.Left path="'color4'.Right" offset="10"/>
				<Button.Material shader="lib://Ghurund/shaders/DirectX/ui/controlWithShadow.hlsl">
					<Parameter name="backgroundColor" value="#ffff0000"/>
				</Button.Material>
			</Button>
			<CheckBox left="'colorTheme'.Right" name="enabledCheckBox">
				<TextBlock width="Parent.Width" height="Parent.Height">enabled</TextBlock>
			</CheckBox>
			<CheckBox left="'enabledCheckBox'.Right" name="themeCheckBox">
				<TextBlock width="Parent.Width" height="Parent.Height">theme</TextBlock>
			</CheckBox>
		</ControlGroup>
	</ControlGroup>
</PreviewLayout>