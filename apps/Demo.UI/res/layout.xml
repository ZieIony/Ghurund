<?xml version="1.0" encoding="utf-8"?>
<ConstraintLayout xmlns="https://github.com/Zielony/Ghurund/Engine/UISchema.xsd">
	<ColorView width="Parent.Width" height="Parent.Height" name="background"
			   style="theme://style/ColorView_background"/>
	<VerticalLayout width="Parent.Width" height="Parent.Height" spacing="8">
		<MenuBar name="menuBar" width="Parent.Width" height="content"/>
		<Toolbar name="toolbar" width="Parent.Width" height="content"/>
		<Button layout="lib://Ghurund\layouts\ButtonAccentLayout.xml">
			<DrawableView drawable="resources/button.png" width="content" height="content"/>
		</Button>
		<Button>
			<DrawableView drawable="resources/button.png"/>
		</Button>
		<Button layout="lib://Ghurund\layouts\ButtonFlatLayout.xml">
			<DrawableView drawable="resources/button.png"/>
		</Button>
		<IconButton layout="lib://Ghurund\layouts\ButtonIconLayout.xml" drawable="resources/icons/category 18.png"/>
		<IconButton layout="lib://Ghurund\layouts\ButtonIconOnAccentLayout.xml" drawable="resources/icons/category 18.png"/>
		<Button layout="lib://Ghurund\layouts\ButtonImageLayout.xml">
			<DrawableView drawable="images/buttons.png"/>
		</Button>
		<Button layout="lib://Ghurund\layouts\ButtonOutlinedLayout.xml">
			<DrawableView drawable="resources/button.png"/>
		</Button>
		<HorizontalLayout width="Parent.Width" height="content">
			<ColorView color="#ffff0000" height="40"/>
			<ColorView color="#ff00ff00" height="40"/>
			<ColorView color="#ff0000ff" height="40"/>
		</HorizontalLayout>
		<HorizontalLayout width="Parent.Width" height="content">
			<AdapterLayout width="500" height="300" name="adapterLayout"/>
			<AdapterLayout width="500" height="content" name="adapterLayout2"/>
		</HorizontalLayout>
	</VerticalLayout>
</ConstraintLayout>