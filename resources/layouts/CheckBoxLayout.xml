<?xml version="1.0" encoding="utf-8"?>
<ControlContainer xmlns="https://github.com/Zielony/Ghurund/Engine/UISchema.xsd">
	<ControlGroup width="content" height="content">
		<Control name="icon" alignment="center, center" width="18" height="18">
			<Control.Material shader="lib://Ghurund/shaders/DirectX/ui/checkable.hlsl">
				<Parameter name="image" value="lib://Ghurund/icons/checkbox 18.png"/>
			</Control.Material>
		</Control>
		<ControlContainer width="content" height="content"
						  name="container">
			<ControlContainer.Left path="'icon'.Right" offset="4"/>
		</ControlContainer>
	</ControlGroup>
</ControlContainer>