<?xml version="1.0" encoding="utf-8"?>
<ControlContainer xmlns="https://github.com/Zielony/Ghurund/Engine/UISchema.xsd">
	<ConstraintLayout width="content" height="content"
				  alignment="center, center"
				  orientation="horizontal">
		<ConstraintLayout name="check" alignment="center, center" width="18" height="18">
			<StateIndicator name="state" width="Parent.Width" height="Parent.Height"/>
			<Control name="drawable" width="18" height="18">
				<Control.Material shader="lib://Ghurund/shaders/DirectX/ui/image.hlsl">
					<Parameter name="image" value="lib://Ghurund/icons/checkbox checked 18.png"/>
				</Control.Material>
			</Control>
		</ConstraintLayout>
		<ControlContainer width="content" height="content"
						  name="container">
			<ControlContainer.Left path="'check'.Right" offset="4"/>
		</ControlContainer>
	</ConstraintLayout>
</ControlContainer>