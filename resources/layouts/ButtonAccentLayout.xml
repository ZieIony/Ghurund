<?xml version="1.0" encoding="utf-8"?>
<ConstraintLayout xmlns="https://github.com/Zielony/Ghurund/Engine/UISchema.xsd" name="button layout">
	<Shadow width="Parent.Width" height="Parent.Height" shape="roundRect, 2"/>
	<Clip width="Parent.Width" height="Parent.Height" shape="roundRect, 2">
		<ConstraintLayout name="button content">
			<ConstraintLayout.Width path="Parent.Width"/>
			<ConstraintLayout.Height path="Parent.Height"/>
			<ColorView width="Parent.Width" height="Parent.Height"
					   style="theme://style/ColorView_accent" name="background"/>
			<StateIndicator name="state" width="Parent.Width" height="Parent.Height"/>
			<ControlContainer name="container">
				<ControlContainer.Left path="Parent.Left" offset="8"/>
				<ControlContainer.Top path="Parent.Top" offset="4"/>
				<ControlContainer.Width path="content" offset="8"/>
				<ControlContainer.Height path="content" offset="4"/>
			</ControlContainer>
		</ConstraintLayout>
	</Clip>
</ConstraintLayout>
